# --------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# --------------------------------------------------------------------------

# --- Shopify Admin API -------------------------------------------------
# Create a custom app in Shopify Admin > Settings > Apps and sales channels
# > Develop apps, then generate an Admin API access token with the scopes
# you need (e.g. write_products, read_products).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10
# Only needed if using OAuth (public app) instead of a custom-app token:
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=write_products,read_products

# --- Printify API --------------------------------------------------------
# Generate a Personal Access Token at https://printify.com/app/account/api
PRINTIFY_API_TOKEN=your_printify_personal_access_token
PRINTIFY_SHOP_ID=your_printify_shop_id

# --- Image / Asset Generation --------------------------------------------
# Pick whichever free-tier provider you're using; the code should read only
# the one(s) actually configured.

# Hugging Face Inference API (free tier): https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Replicate (free credits on signup): https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Personalization (Printify Automated Personalization) ----------------
# Enable customer-driven personalization layers (custom text, images)
ENABLE_PERSONALIZATION=true

# Character limit for custom text personalization
PERSONALIZATION_TEXT_LIMIT=50

# Hold personalized products in draft status for manual review before printing
# Prevents obscene/offensive text from being printed
PERSONALIZATION_HOLD_FOR_REVIEW=true

# --- App / Server ---------------------------------------------------------
PORT=3000
NODE_ENV=development

# Webhook shared secret(s) for verifying inbound Printify/Shopify webhooks
PRINTIFY_WEBHOOK_SECRET=
SHOPIFY_WEBHOOK_SECRET=

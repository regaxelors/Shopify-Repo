# Lemon Squeezy Webhook Configuration
# Get this from your Lemon Squeezy dashboard webhook settings
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Configuration
# Generate a personal access token at https://github.com/settings/tokens
# Requires: repo, workflow scopes
GITHUB_ACCESS_TOKEN=your_github_personal_access_token_here

# GitHub Repository (format: owner/repo-name)
# Example: anthropics/claude-code
GITHUB_REPO_NAME=owner/repo-name

# Optional: Server Configuration
# Port for webhook server (default: 3000)
PORT=3000

# Optional: Logging
LOG_LEVEL=info
